# ============================================================================
# ts_momentum strategy -- DEDICATED Alpaca PAPER account
# ============================================================================
# This file is for the SEPARATE paper account you created for the ts_momentum
# (banded time-series momentum) strategy. It is kept apart from the main .env on
# purpose: the $1,500 paper account in .env belongs to a DIFFERENT, already-
# automated strategy, and these two must never share keys.
#
# SETUP:
#   1. Copy this file to ".env.tsmom"   (note: .env.tsmom is gitignored)
#   2. Paste the PAPER keys for your NEW ts_momentum account below.
#   3. These MUST be paper keys. The client refuses the live endpoint.
#
# Only live/ts_momentum_paper_trader.py reads this file. It does NOT read the
# main .env, so it cannot touch the other strategy's account.

# --- New ts_momentum paper account keys (paste yours here) ------------------
TSMOM_ALPACA_API_KEY=your_tsmom_paper_key_id_here
TSMOM_ALPACA_SECRET_KEY=your_tsmom_paper_secret_here

# Paper endpoint. Do NOT change this to the live URL -- the client will refuse.
TSMOM_ALPACA_BASE_URL=https://paper-api.alpaca.markets
