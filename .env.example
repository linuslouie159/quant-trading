# Copy this file to ".env" and fill in your Alpaca PAPER keys.
# .env is gitignored -- never commit real keys.
#
# Get paper keys from: https://app.alpaca.markets/  (Paper Trading -> API Keys)
# These MUST be paper keys. The code refuses to talk to the live endpoint.

ALPACA_API_KEY=your_paper_key_id_here
ALPACA_SECRET_KEY=your_paper_secret_here

# Paper endpoint. Do NOT change this to the live URL -- the client will refuse.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Telegram bot (optional; powers live/telegram_bot.py) ---
# TELEGRAM_BOT_TOKEN : create a bot via @BotFather, paste its token here.
# TELEGRAM_ALLOWED_IDS: comma-separated numeric user IDs allowed to use the bot
#                       (message @userinfobot to find yours). Required -- the bot
#                       ignores everyone not on this list.
TELEGRAM_BOT_TOKEN=your_botfather_token_here
TELEGRAM_ALLOWED_IDS=123456789
